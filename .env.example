# Copia questo file in backend/.env e personalizza i valori

# Django
SECRET_KEY=cambia-questa-chiave-segreta-in-produzione
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (SQLite in sviluppo, PostgreSQL in produzione)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=music_platform
# DB_USER=postgres
# DB_PASSWORD=password
# DB_HOST=localhost
# DB_PORT=5432

# CORS (origini React consentite)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ──────────────────────────────────────────────────────────────
# Email — reset password
# Se EMAIL_HOST è vuoto → le email vengono stampate nel terminale (sviluppo)
# ──────────────────────────────────────────────────────────────

# Opzione A — Gmail con App Password
# 1. Attiva 2FA su Google: https://myaccount.google.com/security
# 2. Genera una App Password: https://myaccount.google.com/apppasswords
# 3. Decomenta e compila:
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=tua@gmail.com
# EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx
# DEFAULT_FROM_EMAIL=tua@gmail.com

# Opzione B — MailTrap (cattura email in un inbox di test, non arrivano ai destinatari reali)
# 1. Registrati gratis su https://mailtrap.io
# 2. Vai su Email Testing → My Inbox → SMTP Settings → seleziona "Django"
# 3. Decomenta e compila:
# EMAIL_HOST=sandbox.smtp.mailtrap.io
# EMAIL_PORT=2525
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=<username-mailtrap>
# EMAIL_HOST_PASSWORD=<password-mailtrap>
# DEFAULT_FROM_EMAIL=noreply@musicplatform.local

FRONTEND_URL=http://localhost:5173
